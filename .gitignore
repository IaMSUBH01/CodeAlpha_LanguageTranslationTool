# ============================================================
# .gitignore — Python / Streamlit Project
# CodeAlpha Internship — Language Translation Tool
# ============================================================

# ── Python cache & bytecode ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual environments ─────────────────────────────────────
venv/
.venv/
env/
ENV/
.env
virtualenv/

# ── IDEs & Editors ───────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
Thumbs.db

# ── macOS metadata (ALL levels) ─────────────────────────────
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# ── Jupyter Notebooks ────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Generated audio files ────────────────────────────────────
*.mp3
*.wav
*.ogg
*.flac
audio_output/
tts_cache/

# ── Temporary / OS files ─────────────────────────────────────
*.tmp
*.temp
*.log
*.bak
*.orig

# ── Distribution / packaging ─────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/

# ── Testing ──────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# ── Streamlit secrets & config ───────────────────────────────
.streamlit/secrets.toml
.streamlit/config.toml

# ── Environment variables ────────────────────────────────────
.env
.env.*
*.env
.env.local
.env.production
.env.staging

# ── Security / Credentials (NEVER commit these) ──────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert
service_account*.json
credentials*.json
secrets*.json
*_credentials.json
gcp_*.json
aws_*.json

# ── Pip cache ────────────────────────────────────────────────
pip-wheel-metadata/
.pip/

# ── MyPy ─────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
